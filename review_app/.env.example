# Copy this to .env and fill in your values
# Never commit .env to git

# ── Gemini ────────────────────────────────────────────────────────────────────
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# ── Tavily (company research before email generation) ─────────────────────────
# Get a key from: https://tavily.com/
# If left empty, research is skipped and email is generated from lead data only.
# If you already have TAVILY_API_KEY in the marketing-swarm .env, it will be
# used automatically as a fallback — no need to duplicate it here.
TAVILY_API_KEY=your-tavily-api-key-here

# ── SMTP (Google Workspace App Password) ──────────────────────────────────────
# Generate at: myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@buteforce.com
SMTP_PASS=your-16-char-app-password-here

# ── Google Sheets ──────────────────────────────────────────────────────────────
# 1. Go to console.cloud.google.com (project: buteforce)
# 2. IAM & Admin → Service Accounts → Create Service Account
# 3. Create a JSON key for it, download the file
# 4. Paste the ENTIRE JSON contents as a single line below
# 5. Share your Google Sheet with the service account email (Editor access)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"buteforce","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"outreach@buteforce.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

SHEET_ID=1KghW03YIgrvWhSPzKTgw_uyGU2BcMVtB5nP1tPZUdfQ
SHEET_NAME=Clients detail
